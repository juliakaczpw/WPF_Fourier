<Window x:Class="Fourier.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Fourier"
        mc:Ignorable="d"
        Title="Fourier Plotter" Height="750" Width="1200" ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="80*"/>
            <ColumnDefinition Width="20*"/>
        </Grid.ColumnDefinitions>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="85*"/>
            <RowDefinition Height="15*"/>
        </Grid.RowDefinitions>

        <Menu Grid.Row="0" Grid.ColumnSpan="2">
            <MenuItem Header="File">
                <MenuItem Header="New" Click="NewMenuItem"/>
                <MenuItem Header="Open" Click="OpenMenuItem"/>
                <MenuItem Header="Save" Click="SaveMenuItem"/>
            </MenuItem>
            <MenuItem Header="Exit" Click="ExitMenuItem_Click"/>
        </Menu>

        <GroupBox Header="Plotter" Grid.Row="1" Grid.Column="0">
            <Image x:Name="PlotterImage" Stretch="None" HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </GroupBox>

        <GroupBox Header="Circles" Grid.Row="1" Grid.Column="1">
            <DataGrid x:Name="CirclesDataGrid"/>
        </GroupBox>

        <ProgressBar x:Name="MainProgressBar" Grid.Row="2" Grid.Column="0"
                     Minimum="0" Maximum="100" Value="0" Margin="10"/>

        <GroupBox Header="Actions" Grid.Row="2" Grid.Column="1">
            <StackPanel>
                <Button x:Name="StartButton" Content="Start" Click="StartButtonItem"/>
                <Button x:Name="PauseButton" Content="Pause" Click="PauseButtonItem"/>
                <Button x:Name="ResetButton" Content="Reset" Click="ResetButtonItem"/>
            </StackPanel>
        </GroupBox>

    </Grid>
</Window>
